{%- comment -%} Jana Mobile Bottom Nav - 5 Icon Grid {%- endcomment -%}

<nav class="jana-bottom-nav" aria-label="Mobile navigation">
  <!-- Home -->
  <a href="/" class="jana-bottom-nav__item {% if request.path == '/' %}jana-bottom-nav__item--active{% endif %}">
    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <span class="sans">Home</span>
  </a>

  <!-- Shop -->
  <a href="/collections/all" class="jana-bottom-nav__item {% if request.path contains '/collections' %}jana-bottom-nav__item--active{% endif %}">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    <span class="sans">Shop</span>
  </a>

  <!-- Search -->
  <button class="jana-bottom-nav__item" data-jana-search-open>
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <span class="sans">Search</span>
  </button>

  <!-- Wishlist -->
  <a href="/pages/wishlist" class="jana-bottom-nav__item">
    <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    <span class="sans">Wishlist</span>
  </a>

  <!-- Cart -->
  <button class="jana-bottom-nav__item" data-jana-cart-open>
    <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
    <span class="sans">Cart</span>
    <span class="jana-bottom-nav__badge" data-jana-cart-count style="{% if cart.item_count == 0 %}display:none{% endif %}">{{ cart.item_count }}</span>
  </button>
</nav>
