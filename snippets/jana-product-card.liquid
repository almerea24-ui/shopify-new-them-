{%- comment -%}
  Jana Product Card - Exact Demo Match
  Usage: {% render 'jana-product-card', product: product, index: forloop.index %}
{%- endcomment -%}

{%- liquid
  assign v = product.selected_or_first_available_variant
  assign on_sale = false
  if v.compare_at_price > v.price
    assign on_sale = true
    assign discount = v.compare_at_price | minus: v.price | times: 100 | divided_by: v.compare_at_price
  endif
  assign sold_out = true
  if v.available
    assign sold_out = false
  endif
  assign idx = index | default: 1
-%}

<div class="jana-card card-animate stagger-{{ idx }}">
  <div class="jana-card__media">
    <a href="{{ product.url }}">
      {% if product.featured_image != blank %}
        <img class="jana-card__img jana-card__img--primary {% if product.images.size > 1 %}has-hover{% endif %}" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" width="600" height="800" loading="lazy">
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}

      {% if product.images.size > 1 %}
        <img class="jana-card__img jana-card__img--hover" src="{{ product.images[1] | image_url: width: 600 }}" alt="{{ product.images[1].alt | escape }}" width="600" height="800" loading="lazy">
      {% endif %}
    </a>

    <!-- Badges -->
    <div class="jana-card__badges">
      {% if sold_out %}
        <span class="jana-card__badge jana-card__badge--limited sans">Sold Out</span>
      {% else %}
        {% if on_sale %}
          <span class="jana-card__badge jana-card__badge--sale sans">-{{ discount }}%</span>
        {% endif %}
        {% if product.tags contains 'new' %}
          <span class="jana-card__badge jana-card__badge--new sans">New</span>
        {% endif %}
        {% if product.tags contains 'bestseller' %}
          <span class="jana-card__badge jana-card__badge--best sans">Bestseller</span>
        {% endif %}
      {% endif %}
    </div>

    <!-- Wishlist -->
    <button class="jana-card__wishlist" aria-label="Add to wishlist">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>

    <!-- Quick Add -->
    {% unless sold_out %}
      {% if product.variants.size == 1 %}
        <form data-jana-add-to-cart>
          <input type="hidden" name="id" value="{{ v.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" class="jana-card__quick-add sans">Quick Add</button>
        </form>
      {% else %}
        <a href="{{ product.url }}" class="jana-card__quick-add sans" style="text-decoration:none;">Select Options</a>
      {% endif %}
    {% endunless %}
  </div>

  <div class="jana-card__info">
    {% if product.type != blank %}
      <p class="jana-card__category sans">{{ product.type }}</p>
    {% endif %}

    <a href="{{ product.url }}" class="jana-card__title">{{ product.title }}</a>

    <!-- Price -->
    <div class="jana-card__price">
      {% if on_sale %}
        <span class="jana-card__price-current">{{ v.price | money }}</span>
        <span class="jana-card__price-compare sans">{{ v.compare_at_price | money }}</span>
        <span class="jana-card__price-discount sans">-{{ discount }}%</span>
      {% else %}
        <span class="jana-card__price-current">{{ v.price | money }}</span>
      {% endif %}
    </div>

    <!-- Color Swatches -->
    {%- liquid
      assign color_option = product.options_by_name['Color']
      unless color_option
        assign color_option = product.options_by_name['Colour']
      endunless
    -%}
    {% if color_option %}
      <div class="jana-card__swatches">
        {%- assign max_swatches = 6 -%}
        {% for value in color_option.values limit: max_swatches %}
          {%- assign swatch_color = value | downcase | replace: ' ', '' -%}
          {%- comment -%} Map common color names to hex {%- endcomment -%}
          {%- case swatch_color -%}
            {%- when 'black' -%}{%- assign hex = '#000000' -%}
            {%- when 'white' -%}{%- assign hex = '#ffffff' -%}
            {%- when 'red' -%}{%- assign hex = '#dc2626' -%}
            {%- when 'blue' -%}{%- assign hex = '#2563eb' -%}
            {%- when 'navy' -%}{%- assign hex = '#1e3a5f' -%}
            {%- when 'green' -%}{%- assign hex = '#16a34a' -%}
            {%- when 'beige' -%}{%- assign hex = '#d4b896' -%}
            {%- when 'cream' -%}{%- assign hex = '#fffdd0' -%}
            {%- when 'tan' -%}{%- assign hex = '#d2b48c' -%}
            {%- when 'brown' -%}{%- assign hex = '#8b4513' -%}
            {%- when 'grey','gray' -%}{%- assign hex = '#9ca3af' -%}
            {%- when 'pink' -%}{%- assign hex = '#ec4899' -%}
            {%- when 'orange' -%}{%- assign hex = '#f97316' -%}
            {%- when 'yellow' -%}{%- assign hex = '#eab308' -%}
            {%- when 'purple' -%}{%- assign hex = '#9333ea' -%}
            {%- when 'olive' -%}{%- assign hex = '#6b7c3e' -%}
            {%- when 'khaki' -%}{%- assign hex = '#c3b091' -%}
            {%- when 'camel' -%}{%- assign hex = '#c19a6b' -%}
            {%- else -%}{%- assign hex = '#cccccc' -%}
          {%- endcase -%}
          <span class="jana-card__swatch {% if forloop.first %}jana-card__swatch--active{% endif %}" style="background-color:{{ hex }};" title="{{ value }}"></span>
        {% endfor %}
        {%- if color_option.values.size > max_swatches -%}
          {%- assign extra = color_option.values.size | minus: max_swatches -%}
          <span style="font-size:9px;color:var(--color-text-muted);" class="sans">+{{ extra }}</span>
        {%- endif -%}
      </div>
    {% endif %}
  </div>
</div>
