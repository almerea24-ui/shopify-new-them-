<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {%- render 'meta-tags' -%}

    <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

    <meta name="theme-color" content="#111111">

    <!-- Jana Fonts -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Cairo:wght@300;400;500&family=Inter:wght@300;400&family=DM+Sans:wght@300;400&family=DM+Serif+Display:ital@0;1&display=swap">

    <!-- Jana CSS -->
    {{ 'jana.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}
  </head>

  <body>
    <!-- Header -->
    {% sections 'header-group' %}

    <!-- Main Content -->
    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    <!-- Footer -->
    {% sections 'footer-group' %}

    <!-- Jana Cart Drawer -->
    {% render 'jana-cart-drawer' %}

    <!-- Jana Mobile Bottom Nav -->
    {% render 'jana-mobile-nav' %}

    <!-- Jana Back to Top -->
    <button class="jana-btt" data-jana-btt aria-label="Back to top">
      <svg viewBox="0 0 24 24" fill="none"><line x1="12" y1="19" x2="12" y2="5" stroke="currentColor" stroke-width="1.5"/><polyline points="5 12 12 5 19 12" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
    </button>

    <!-- Jana JavaScript -->
    <script src="{{ 'jana.js' | asset_url }}"></script>
  </body>
</html>
