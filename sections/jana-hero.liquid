<!-- Jana Hero Section -->
<section class="jana-section jana-hero" style="min-height: {{ section.settings.height }}vh;">
  <!-- Slides -->
  <div class="jana-hero__slides">
    {% for block in section.blocks %}
      <div class="jana-hero__slide {% if forloop.first %}active{% endif %}" data-jana-hero-slide {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 1920 }}"
            alt="{{ block.settings.heading | escape }}"
            width="1920"
            height="1080"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            fetchpriority="{% if forloop.first %}high{% else %}low{% endif %}"
          >
        {% else %}
          {{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <!-- Overlay -->
  <div class="jana-hero__overlay" style="background: linear-gradient(to top, {{ section.settings.overlay_color }} 0%, rgba(0,0,0,0.1) 50%, transparent 100%);"></div>

  <!-- Content -->
  <div class="jana-hero__content">
    {% for block in section.blocks %}
      {% if forloop.first %}
        {% if block.settings.subtitle != blank %}
          <p class="jana-hero__subtitle">{{ block.settings.subtitle }}</p>
        {% endif %}
        <h1 class="jana-hero__title jana-serif">{{ block.settings.heading }}</h1>
        {% if block.settings.button_text != blank %}
          <a href="{{ block.settings.button_link }}" class="jana-hero__btn">
            {{ block.settings.button_text }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>

  <!-- Dots -->
  {% if section.blocks.size > 1 %}
    <div class="jana-hero__dots">
      {% for block in section.blocks %}
        <button class="jana-hero__dot {% if forloop.first %}active{% endif %}" data-jana-hero-dot aria-label="Slide {{ forloop.index }}"></button>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Jana Hero",
  "class": "jana-hero-section",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "Section Height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "vh"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "rgba(0,0,0,0.6)"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "New Collection"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Minimal Elegance"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jana Hero",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subtitle": "Spring / Summer 2025",
            "heading": "Minimal Elegance",
            "button_text": "Explore Collection"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subtitle": "New Arrivals",
            "heading": "Effortless Style",
            "button_text": "Shop Now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
