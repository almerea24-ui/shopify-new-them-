<!-- Jana Footer - 4 Column -->
<footer class="jana-footer">
  <div class="jana-footer__inner">
    <div class="jana-footer__grid">
      <!-- Brand Column -->
      <div>
        <span class="jana-footer__brand serif">{{ section.settings.brand_name | default: shop.name }}</span>
        <p class="jana-footer__tagline sans">{{ section.settings.tagline | default: 'Premium minimal fashion. Thoughtfully designed.' }}</p>
        {% if section.settings.email != blank %}
          <p class="jana-footer__contact sans">✉ {{ section.settings.email }}</p>
        {% endif %}
        {% if section.settings.phone != blank %}
          <p class="jana-footer__contact sans">☎ {{ section.settings.phone }}</p>
        {% endif %}
        {% if section.settings.hours != blank %}
          <p class="jana-footer__contact sans">🕐 {{ section.settings.hours }}</p>
        {% endif %}
        <div class="jana-footer__social">
          {% if section.settings.instagram != blank %}<a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" class="sans">IG</a>{% endif %}
          {% if section.settings.tiktok != blank %}<a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener" class="sans">TK</a>{% endif %}
          {% if section.settings.pinterest != blank %}<a href="{{ section.settings.pinterest }}" target="_blank" rel="noopener" class="sans">PIN</a>{% endif %}
          {% if section.settings.twitter != blank %}<a href="{{ section.settings.twitter }}" target="_blank" rel="noopener" class="sans">X</a>{% endif %}
        </div>
      </div>

      <!-- Menu Columns -->
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          <h4 class="jana-footer__col-title sans">{{ block.settings.heading }}</h4>
          {% if block.type == 'menu' and block.settings.menu != blank %}
            {% for link in block.settings.menu.links %}
              <a href="{{ link.url }}" class="jana-footer__link sans">{{ link.title }}</a>
            {% endfor %}
          {% elsif block.type == 'links' %}
            {% for i in (1..6) %}
              {% assign link_text = 'link_' | append: i | append: '_text' %}
              {% assign link_url = 'link_' | append: i | append: '_url' %}
              {% if block.settings[link_text] != blank %}
                <a href="{{ block.settings[link_url] | default: '#' }}" class="jana-footer__link sans">{{ block.settings[link_text] }}</a>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- Bottom -->
    <div class="jana-footer__bottom">
      <p class="jana-footer__copy sans">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="jana-footer__policies">
        {% for policy in shop.policies %}
          {% if policy %}
            <a href="{{ policy.url }}" class="sans">{{ policy.title }}</a>
          {% endif %}
        {% endfor %}
      </div>
      <div class="jana-footer__payments">
        {% assign pay_types = 'VISA,MC,AMEX,PAYPAL,APPLE PAY,SHOP PAY' | split: ',' %}
        {% for type in pay_types %}
          <span class="jana-footer__pay-icon sans">{{ type }}</span>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Jana Footer",
  "class": "jana-section",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand Name", "default": "JANA" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Premium minimal fashion. Thoughtfully designed, sustainably made." },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@jana.com" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+44 7700 900000" },
    { "type": "text", "id": "hours", "label": "Hours", "default": "Mon-Fri, 9am-6pm GMT" },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "tiktok", "label": "TikTok" },
    { "type": "url", "id": "pinterest", "label": "Pinterest" },
    { "type": "url", "id": "twitter", "label": "Twitter/X" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "links",
      "name": "Links Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Help" },
        { "type": "text", "id": "link_1_text", "label": "Link 1 Text" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_text", "label": "Link 2 Text" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_text", "label": "Link 3 Text" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_text", "label": "Link 4 Text" },
        { "type": "url", "id": "link_4_url", "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_text", "label": "Link 5 Text" },
        { "type": "url", "id": "link_5_url", "label": "Link 5 URL" },
        { "type": "text", "id": "link_6_text", "label": "Link 6 Text" },
        { "type": "url", "id": "link_6_url", "label": "Link 6 URL" }
      ]
    }
  ],
  "presets": [{
    "name": "Jana Footer",
    "blocks": [
      { "type": "menu", "settings": { "heading": "Shop" } },
      { "type": "menu", "settings": { "heading": "Help" } },
      { "type": "menu", "settings": { "heading": "Company" } }
    ]
  }]
}
{% endschema %}
