<!-- Jana Countdown - Live HH:MM:SS, dark bg -->
<section class="jana-countdown" data-jana-countdown data-hours="{{ section.settings.hours }}">
  <p class="jana-countdown__label sans">{{ section.settings.label | default: 'Limited Time Offer' }}</p>
  <h3 class="jana-countdown__title serif">{{ section.settings.heading | default: 'Sale Ends Tonight' }}</h3>
  {% if section.settings.code != blank %}
    <p class="jana-countdown__code sans">Use code <span>{{ section.settings.code }}</span></p>
  {% endif %}
  <div class="jana-countdown__digits">
    <div class="jana-countdown__digit">
      <div class="jana-countdown__digit-value serif" data-jana-cd-hours>00</div>
      <p class="jana-countdown__digit-label sans">HRS</p>
    </div>
    <span class="jana-countdown__separator serif">:</span>
    <div class="jana-countdown__digit">
      <div class="jana-countdown__digit-value serif" data-jana-cd-mins>00</div>
      <p class="jana-countdown__digit-label sans">MIN</p>
    </div>
    <span class="jana-countdown__separator serif">:</span>
    <div class="jana-countdown__digit">
      <div class="jana-countdown__digit-value serif" data-jana-cd-secs>00</div>
      <p class="jana-countdown__digit-label sans">SEC</p>
    </div>
  </div>
  {% if section.settings.button_text != blank %}
    <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="jana-countdown__btn sans">{{ section.settings.button_text }}</a>
  {% endif %}
</section>

{% schema %}
{
  "name": "Jana Countdown",
  "class": "jana-section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Limited Time Offer" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sale Ends Tonight" },
    { "type": "text", "id": "code", "label": "Promo Code", "default": "JANA25" },
    { "type": "range", "id": "hours", "label": "Hours", "min": 1, "max": 72, "step": 1, "default": 24 },
    { "type": "text", "id": "button_text", "label": "Button", "default": "Shop the Sale" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Jana Countdown" }]
}
{% endschema %}
