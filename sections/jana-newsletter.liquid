<!-- Jana Newsletter Section -->
<section class="jana-section jana-newsletter jana-reveal">
  <div class="jana-container" style="max-width: 600px;">
    <h2 class="jana-newsletter__title jana-serif">{{ section.settings.heading | default: 'Stay in the Loop' }}</h2>
    <p class="jana-newsletter__text">{{ section.settings.text | default: 'Be the first to know about new collections, exclusive offers and style inspiration.' }}</p>

    {% form 'customer' %}
      <div class="jana-newsletter__form">
        <input
          type="email"
          name="contact[email]"
          class="jana-newsletter__input"
          placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
          required
          autocomplete="email"
        >
        <input type="hidden" name="contact[tags]" value="newsletter">
        <button type="submit" class="jana-newsletter__submit">
          {{ section.settings.button_text | default: 'Subscribe' }}
        </button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Jana Newsletter",
  "class": "jana-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in the Loop"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Description",
      "default": "Be the first to know about new collections, exclusive offers and style inspiration."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Jana Newsletter"
    }
  ]
}
{% endschema %}
