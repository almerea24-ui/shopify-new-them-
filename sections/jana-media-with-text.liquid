<!-- Jana Brand Story - 2 column: image + text with stats -->
<section class="jana-story reveal">
  <!-- Image -->
  <div class="jana-story__media">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="900" height="1125">
    {% else %}
      <div style="width:100%;height:100%;min-height:400px;background:linear-gradient(135deg,#1a1a2e,#16213e);"></div>
    {% endif %}
    <div class="jana-story__media-overlay"></div>
    {% if section.settings.tag != blank %}
      <p class="jana-story__media-tag sans">{{ section.settings.tag }}</p>
    {% endif %}
  </div>

  <!-- Content -->
  <div class="jana-story__content">
    <p class="jana-section-head__label sans" style="margin-bottom:1rem;">{{ section.settings.label | default: 'Our Story' }}</p>
    <h2 class="jana-section-head__title serif" style="font-size:clamp(1.875rem,4vw,3rem);margin-bottom:1.25rem;">{{ section.settings.heading | default: 'Dressed in Silence' }}</h2>
    <div class="jana-story__divider"></div>

    {% if section.settings.text_1 != blank %}
      <p class="jana-story__text sans">{{ section.settings.text_1 }}</p>
    {% endif %}
    {% if section.settings.text_2 != blank %}
      <p class="jana-story__text sans">{{ section.settings.text_2 }}</p>
    {% endif %}

    <!-- Stats Row -->
    <div class="jana-story__stats">
      <div>
        <p class="jana-story__stat-value serif">{{ section.settings.stat_1_value | default: '10+' }}</p>
        <p class="jana-story__stat-label sans">{{ section.settings.stat_1_label | default: 'Years' }}</p>
      </div>
      <div>
        <p class="jana-story__stat-value serif">{{ section.settings.stat_2_value | default: '50K+' }}</p>
        <p class="jana-story__stat-label sans">{{ section.settings.stat_2_label | default: 'Customers' }}</p>
      </div>
      <div>
        <p class="jana-story__stat-value serif">{{ section.settings.stat_3_value | default: '120+' }}</p>
        <p class="jana-story__stat-label sans">{{ section.settings.stat_3_label | default: 'Countries' }}</p>
      </div>
    </div>

    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_link | default: '/pages/about' }}" class="jana-story__cta sans">
        {{ section.settings.cta_text }} <span></span>
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Jana Brand Story",
  "class": "jana-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "tag", "label": "Image Tag", "default": "Est. 2019" },
    { "type": "text", "id": "label", "label": "Label", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Dressed in Silence" },
    { "type": "textarea", "id": "text_1", "label": "Paragraph 1", "default": "We believe that true elegance lies in simplicity. Each piece in our collection is thoughtfully designed to transcend seasons and trends." },
    { "type": "textarea", "id": "text_2", "label": "Paragraph 2", "default": "Our commitment to sustainable practices means every garment is crafted with care for both the wearer and the world." },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 Value", "default": "10+" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 Label", "default": "Years" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 Value", "default": "50K+" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 Label", "default": "Customers" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 Value", "default": "120+" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 Label", "default": "Countries" },
    { "type": "text", "id": "cta_text", "label": "Button Text", "default": "About Us" },
    { "type": "url", "id": "cta_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Jana Brand Story" }]
}
{% endschema %}
