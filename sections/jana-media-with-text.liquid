<!-- Jana Media with Text -->
<section class="jana-section jana-reveal">
  <div class="jana-container">
    <div class="jana-media-text" style="{% if section.settings.reverse %}direction: rtl;{% endif %}">
      <!-- Image -->
      <div class="jana-media-text__image">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.heading | escape }}"
            width="900"
            height="1125"
            loading="lazy"
          >
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <!-- Content -->
      <div class="jana-media-text__content" style="direction: ltr;">
        {% if section.settings.subtitle != blank %}
          <p class="jana-label" style="margin-bottom: 1rem;">{{ section.settings.subtitle }}</p>
        {% endif %}

        <h2 class="jana-heading jana-heading-md jana-serif" style="margin-bottom: 1rem;">
          {{ section.settings.heading | default: 'Our Story' }}
        </h2>

        {% if section.settings.text != blank %}
          <p class="jana-body" style="color: var(--jana-muted); margin-bottom: 1.5rem; max-width: 420px;">
            {{ section.settings.text }}
          </p>
        {% endif %}

        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="jana-btn jana-btn--secondary">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Jana Media with Text",
  "class": "jana-media-text-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted with Purpose"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Every piece in our collection is thoughtfully designed with sustainability and timeless style in mind."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "reverse",
      "label": "Reverse Layout",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Jana Media with Text"
    }
  ]
}
{% endschema %}
