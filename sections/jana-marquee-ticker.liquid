<!-- Jana Marquee Ticker (Black Bar) -->
<div class="jana-ticker" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
  <div class="jana-ticker__track">
    {% for i in (1..4) %}
      {% for block in section.blocks %}
        <span class="jana-ticker__item sans" {{ block.shopify_attributes }}>{{ block.settings.text }} <span class="jana-ticker__dot">.</span></span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Jana Ticker",
  "class": "jana-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" }
  ],
  "blocks": [
    { "type": "text", "name": "Text", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Free Shipping Over $150" }
    ]}
  ],
  "presets": [{
    "name": "Jana Ticker",
    "blocks": [
      { "type": "text", "settings": { "text": "Free Shipping Over $150" } },
      { "type": "text", "settings": { "text": "New Collection SS25" } },
      { "type": "text", "settings": { "text": "Sustainably Made" } },
      { "type": "text", "settings": { "text": "Ethically Sourced" } },
      { "type": "text", "settings": { "text": "Free Returns 30 Days" } }
    ]
  }]
}
{% endschema %}
