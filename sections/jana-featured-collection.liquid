<!-- Jana Featured Collection -->
<section class="reveal" style="padding:4rem 0;">
  <div class="jana-container">
    <!-- Section Header -->
    <div class="jana-section-head">
      <div>
        <p class="jana-section-head__label sans">Collection</p>
        <h2 class="jana-section-head__title serif">
          {% if section.settings.heading != blank %}
            {{ section.settings.heading }}
          {% elsif section.settings.collection != blank %}
            {{ section.settings.collection.title }}
          {% else %}
            Featured Products
          {% endif %}
        </h2>
      </div>
      {% if section.settings.collection != blank %}
        <a href="{{ section.settings.collection.url }}" class="jana-section-head__link sans">
          {{ section.settings.link_text | default: 'View All' }} <span></span>
        </a>
      {% endif %}
    </div>

    <!-- Product Grid -->
    <div class="jana-grid jana-grid--gap-y">
      {% if section.settings.collection != blank %}
        {% for product in section.settings.collection.products limit: section.settings.max_products %}
          {% render 'jana-product-card', product: product, index: forloop.index %}
        {% endfor %}
      {% else %}
        {% for i in (1..section.settings.max_products) %}
          <div class="jana-card card-animate stagger-{{ i }}">
            <div class="jana-card__media">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="jana-card__info">
              <p class="jana-card__category sans">Brand Name</p>
              <span class="jana-card__title">Sample Product {{ i }}</span>
              <div class="jana-card__price"><span class="jana-card__price-current">$99.00</span></div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Jana Featured Collection",
  "class": "jana-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "max_products", "label": "Max Products", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "range", "id": "columns_desktop", "label": "Columns (Desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_mobile", "label": "Columns (Mobile)", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "text", "id": "link_text", "label": "Link Text", "default": "View All" }
  ],
  "presets": [{ "name": "Jana Featured Collection" }]
}
{% endschema %}
