<!-- Jana Announcement Bar -->
<div class="jana-section jana-announcement" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="jana-announcement__track">
    {% for i in (1..4) %}
      {% for block in section.blocks %}
        <div class="jana-announcement__item" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
          {% unless forloop.last %}<span>&#9670;</span>{% endunless %}
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Jana Announcement Bar",
  "class": "jana-announcement-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over $150"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jana Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "Free shipping on orders over $150" } },
        { "type": "message", "settings": { "text": "New Season Collection Available" } },
        { "type": "message", "settings": { "text": "Easy Returns Within 30 Days" } }
      ]
    }
  ]
}
{% endschema %}
