<!-- Jana Announcement Bar - Rotating Messages -->
{%- liquid
  assign msg_count = section.blocks.size
-%}
<div class="jana-announce" data-jana-announce style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
  {% if msg_count > 1 %}
    <button class="jana-announce__arrow jana-announce__arrow--prev" data-jana-announce-prev aria-label="Previous">&lsaquo;</button>
  {% endif %}

  {% for block in section.blocks %}
    <p class="jana-announce__text" data-jana-announce-msg style="{% unless forloop.first %}display:none;{% endunless %}" {{ block.shopify_attributes }}>
      {% if block.settings.link != blank %}
        <a href="{{ block.settings.link }}" style="color:inherit;text-decoration:none;">{{ block.settings.text }}</a>
      {% else %}
        {{ block.settings.text }}
      {% endif %}
    </p>
  {% endfor %}

  {% if msg_count > 1 %}
    <button class="jana-announce__arrow jana-announce__arrow--next" data-jana-announce-next aria-label="Next">&rsaquo;</button>
  {% endif %}
</div>

{% schema %}
{
  "name": "Jana Announcement",
  "class": "jana-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping on orders over $150" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Jana Announcement",
    "blocks": [
      { "type": "message", "settings": { "text": "Free shipping on orders over $150" } },
      { "type": "message", "settings": { "text": "New Collection SS25 — Shop Now" } },
      { "type": "message", "settings": { "text": "Free returns within 30 days" } }
    ]
  }]
}
{% endschema %}
