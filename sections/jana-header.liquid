<!-- Jana Header -->
<header class="jana-section jana-header" data-jana-header {% if section.settings.transparent %}data-jana-transparent{% endif %}>
  <div class="jana-header__inner">
    <!-- Left: Menu (mobile) + Nav (desktop) -->
    <div class="jana-header__left">
      <button class="jana-header__menu-btn" data-jana-menu-toggle aria-label="Open menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <nav class="jana-header__nav">
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}" class="jana-header__nav-link">{{ link.title }}</a>
        {% endfor %}
      </nav>
    </div>

    <!-- Center: Logo -->
    <div class="jana-header__center">
      <a href="/" class="jana-header__logo jana-serif">
        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name }}"
            class="jana-header__logo-img"
            width="200"
            height="auto"
            loading="eager"
          >
        {% else %}
          {{ section.settings.logo_text | default: shop.name }}
        {% endif %}
      </a>
    </div>

    <!-- Right: Search + Account + Cart -->
    <div class="jana-header__right">
      <button class="jana-header__icon" data-jana-search-toggle aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>

      {% if section.settings.show_account %}
        <a href="{{ routes.account_url }}" class="jana-header__icon" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.show_wishlist %}
        <a href="/pages/wishlist" class="jana-header__icon" aria-label="Wishlist">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </a>
      {% endif %}

      <button class="jana-header__icon" data-jana-cart-toggle aria-label="Cart">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="jana-header__cart-count" data-jana-cart-count style="display:none;">0</span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Drawer Menu -->
<div class="jana-drawer-overlay" data-jana-menu-overlay></div>
<div class="jana-drawer" data-jana-menu-drawer>
  <div class="jana-drawer__header">
    <span class="jana-label">{{ section.settings.menu_title | default: "Menu" }}</span>
    <button class="jana-drawer__close" data-jana-menu-close aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <nav class="jana-drawer__nav">
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}" class="jana-drawer__link jana-serif">{{ link.title }}</a>
    {% endfor %}
  </nav>
</div>

<!-- Search Overlay -->
<div class="jana-search-overlay" data-jana-search-overlay>
  <button class="jana-search-overlay__close" data-jana-search-close aria-label="Close search">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <form action="/search" method="get" class="jana-search-form" role="search">
    <input
      type="search"
      name="q"
      class="jana-search-form__input jana-serif"
      placeholder="{{ section.settings.search_placeholder | default: 'Search...' }}"
      autocomplete="off"
      data-jana-search-input
    >
    <input type="hidden" name="type" value="product">
  </form>
</div>

{% schema %}
{
  "name": "Jana Header",
  "class": "jana-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "JANA",
      "info": "Shown if no logo image is uploaded"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "transparent",
      "label": "Transparent Header (on hero)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show Account Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show Wishlist Icon",
      "default": false
    },
    {
      "type": "text",
      "id": "menu_title",
      "label": "Mobile Menu Title",
      "default": "Menu"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder",
      "default": "Search..."
    }
  ],
  "presets": [
    {
      "name": "Jana Header"
    }
  ]
}
{% endschema %}
