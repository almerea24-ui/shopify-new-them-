<!-- Jana Header - Sticky + Shadow on Scroll + Mega Menu + Search + Mobile Drawer -->
<header class="jana-header" data-jana-header>
  <div class="jana-header__inner">
    <!-- Mobile Hamburger (visible < lg) -->
    <button class="jana-header__hamburger" data-jana-menu-open aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    <!-- Desktop Nav (hidden < lg) -->
    <nav class="jana-header__nav">
      {% for link in section.settings.menu.links %}
        {% if link.links.size > 0 %}
          <button class="jana-header__nav-link sans" data-jana-mega-trigger="{{ forloop.index }}">{{ link.title }}</button>
        {% else %}
          <a href="{{ link.url }}" class="jana-header__nav-link sans">{{ link.title }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <!-- Logo (centered absolutely) -->
    <div class="jana-header__logo">
      <a href="/" class="jana-header__logo-text serif" aria-label="{{ shop.name }}">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="jana-header__logo-img" width="200" height="auto" loading="eager">
        {% else %}
          {{ section.settings.logo_text | default: shop.name }}
        {% endif %}
      </a>
    </div>

    <!-- Right Actions -->
    <div class="jana-header__actions">
      <!-- Search -->
      <button class="jana-header__icon-btn" data-jana-search-open aria-label="Search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      <!-- Wishlist (desktop only) -->
      <a href="/pages/wishlist" class="jana-header__icon-btn jana-header__desktop-only" aria-label="Wishlist">
        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </a>
      <!-- Account (desktop only) -->
      <a href="{{ routes.account_url }}" class="jana-header__icon-btn jana-header__desktop-only" aria-label="Account">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
      </a>
      <!-- Cart -->
      <button class="jana-header__icon-btn" data-jana-cart-open aria-label="Cart">
        <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="jana-header__badge jana-header__badge--cart" data-jana-cart-count style="{% if cart.item_count == 0 %}display:none{% endif %}">{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

  <!-- Mega Menu Dropdowns -->
  {% for link in section.settings.menu.links %}
    {% if link.links.size > 0 %}
      <div class="jana-mega" data-jana-mega="{{ forloop.index }}">
        <div class="jana-mega__inner">
          {% for child in link.links %}
            <div class="jana-mega__col">
              <p class="jana-mega__heading sans">{{ child.title }}</p>
              {% if child.links.size > 0 %}
                {% for grandchild in child.links %}
                  <a href="{{ grandchild.url }}" class="jana-mega__link">{{ grandchild.title }}</a>
                {% endfor %}
              {% else %}
                <a href="{{ child.url }}" class="jana-mega__link">View All</a>
              {% endif %}
            </div>
          {% endfor %}
          <div class="jana-mega__promo">
            <p class="jana-mega__promo-label sans">Exclusive Offer</p>
            <p class="jana-mega__promo-text serif">Free Shipping on Orders Over $150</p>
            <a href="/collections/all" class="jana-mega__promo-btn sans">Shop Now &rarr;</a>
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}

  <!-- Predictive Search Panel -->
  <div class="jana-search" data-jana-search>
    <div class="jana-search__inner">
      <div class="jana-search__input-wrap">
        <form action="/search" method="get">
          <input type="search" name="q" class="jana-search__input serif" placeholder="Search..." autocomplete="off" data-jana-search-input>
          <input type="hidden" name="type" value="product">
        </form>
        <button class="jana-search__icon" data-jana-search-close aria-label="Close search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <p style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.75rem;" class="sans">Popular Searches</p>
      <div class="jana-search__tags">
        {% for block in section.blocks %}
          {% if block.type == 'search_tag' %}
            <a href="/search?q={{ block.settings.text | url_encode }}&type=product" class="jana-search__tag sans" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</header>

<!-- Mobile Drawer Overlay -->
<div class="jana-mobile-overlay" data-jana-menu-overlay></div>

<!-- Mobile Drawer -->
<div class="jana-mobile-drawer" data-jana-menu-drawer>
  <div class="jana-mobile-drawer__header">
    <span class="serif" style="font-size:1.25rem;letter-spacing:0.4em;text-transform:uppercase;font-weight:300;">{{ section.settings.logo_text | default: shop.name }}</span>
    <button class="jana-mobile-drawer__close" data-jana-menu-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none"><path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="1.5"/></svg>
    </button>
  </div>
  <nav class="jana-mobile-drawer__nav">
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}" class="jana-mobile-drawer__link serif">{{ link.title }}</a>
    {% endfor %}
  </nav>
  <div class="jana-mobile-drawer__bottom">
    <a href="{{ routes.account_url }}" class="jana-mobile-drawer__bottom-link sans">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
      Account
    </a>
    <a href="/pages/wishlist" class="jana-mobile-drawer__bottom-link sans">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      Wishlist
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Jana Header",
  "class": "jana-section",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "text", "id": "logo_text", "label": "Logo Text", "default": "JANA" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ],
  "blocks": [
    {
      "type": "search_tag",
      "name": "Search Tag",
      "settings": [
        { "type": "text", "id": "text", "label": "Tag Text", "default": "Dresses" }
      ]
    }
  ],
  "enabled_on": { "groups": ["header"] },
  "presets": [{
    "name": "Jana Header",
    "blocks": [
      { "type": "search_tag", "settings": { "text": "Tops" } },
      { "type": "search_tag", "settings": { "text": "Dresses" } },
      { "type": "search_tag", "settings": { "text": "Outerwear" } },
      { "type": "search_tag", "settings": { "text": "Accessories" } },
      { "type": "search_tag", "settings": { "text": "Linen" } },
      { "type": "search_tag", "settings": { "text": "Cashmere" } }
    ]
  }]
}
{% endschema %}
